# Core
NODE_ENV=development
APP_ENV=dev
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://gympro:gympro@localhost:5432/gympro?schema=public

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Email
EMAIL_PROVIDER=mailhog
MAIL_FROM=no-reply@gympro.local
RESEND_API_KEY=
SENDGRID_API_KEY=

# Storage
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gympro-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Security
H_CAPTCHA_SITE_KEY=
H_CAPTCHA_SECRET=
CORS_ORIGIN=http://localhost:3000
CSP_REPORT_URI=

# Feature flags
FF_CHECKIN_QR=false
FF_VISIT_360=false
FF_LIGHT_MODE=true
